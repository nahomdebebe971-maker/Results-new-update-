{
  "entities": {
    "SchoolConfig": {
      "title": "School Configuration",
      "description": "Global settings for the school instance",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "schoolLogo": { "type": "string" },
        "academicYear": { "type": "string" },
        "passMark": { "type": "number" },
        "contactInfo": { "type": "string" },
        "analyticsRanges": { "type": "array" },
        "studentIdPrefix": { "type": "string" },
        "resultsPublished": { "type": "boolean" }
      },
      "required": ["schoolName", "academicYear", "passMark"]
    },
    "AdminAccount": {
      "title": "Admin Account",
      "description": "System administrator roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Information about a school teacher with assignments",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "teacherId": { "type": "string" },
        "uid": { "type": "string" },
        "assignedSubjects": { "type": "array" },
        "assignedClasses": { "type": "array" },
        "homeroomTeacherFor": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "teacherId"]
    },
    "PublishedResult": {
      "title": "Published Result",
      "description": "Finalized, read-optimized student result document",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "verificationId": { "type": "string" },
        "studentProfile": { "type": "object" },
        "results": { "type": "object" },
        "summaries": { "type": "object" },
        "conduct": { "type": "string" },
        "absent": { "type": "number" },
        "recommendation": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "verificationId"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System action tracking",
      "type": "object",
      "properties": {
        "user": { "type": "string" },
        "role": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AnalyticsCache": {
      "title": "Analytics Cache",
      "description": "Pre-calculated analytics data",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "data": { "type": "object" },
        "calculatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Grade": {
      "title": "Grade & Section",
      "description": "Defines a class like 9A",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "section": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "section"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Curriculum subjects",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "passkey": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "passkey"]
    },
    "Student": {
      "title": "Student",
      "description": "Information and calculated results for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "name": { "type": "string" },
        "sex": { "type": "string", "enum": ["M", "F"] },
        "age": { "type": "number" },
        "grade": { "type": "string" },
        "section": { "type": "string" },
        "results": { "type": "object" },
        "semester1": { "type": "object" },
        "semester2": { "type": "object" },
        "final": { "type": "object" },
        "conduct": { "type": "string" },
        "absent": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "name", "grade", "section"]
    },
    "Mark": {
      "title": "Student Mark",
      "description": "Individual subject marks for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "grade": { "type": "string" },
        "section": { "type": "string" },
        "semester1": { "type": "number" },
        "semester2": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subjectId"]
    },
    "SchoolAnalytics": {
      "title": "School Analytics",
      "description": "Aggregated school performance data",
      "type": "object",
      "properties": {
        "updatedAt": { "type": "string", "format": "date-time" },
        "data": { "type": "object" }
      },
      "required": ["updatedAt", "data"]
    }
  },
  "firestore": {
    "/config/school": {
      "schema": "SchoolConfig",
      "description": "Global school configuration"
    },
    "/adminAccounts/{uid}": {
      "schema": "AdminAccount",
      "description": "System administrator accounts"
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Registered teachers with assignments"
    },
    "/publishedResults/{verificationId}": {
      "schema": "PublishedResult",
      "description": "Locked student results for portal access"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System activity logs"
    },
    "/analyticsCache/{cacheId}": {
      "schema": "AnalyticsCache",
      "description": "Pre-calculated performance data"
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Grade levels and sections"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "School subjects with passkeys"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student profiles and summarized results"
    },
    "/marks/{markId}": {
      "schema": "Mark",
      "description": "Individual student subject marks"
    },
    "/analytics/{analyticsId}": {
      "schema": "SchoolAnalytics",
      "description": "Aggregated analytical reports"
    }
  }
}
