rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow all collections
    match /config/school { allow read, write: if true; }
    match /teachers/{id} { allow read, write: if true; }
    match /students/{id} { allow read, write: if true; }
    match /grades/{id} { allow read, write: if true; }
    match /subjects/{id} { allow read, write: if true; }
    match /marks/{id} { allow read, write: if true; }
    match /admins/{id} { allow read, write: if true; }
    
    // Catch-all
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
